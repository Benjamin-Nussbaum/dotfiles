[column]
    ui = auto
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[log]
	date = iso
[init]
	defaultBranch = master
[diff]
	algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true
[grep]
    patternType = perl
[push]
	autoSetupRemote = true
    followTags = true
[fetch]
    prune = true
    pruneTags = true
    all = true
[pull]
	rebase = true
[merge]
	conflictstyle = zdiff3
[rebase]
	autosquash = true
	autostash = true
	missingCommitsCheck = error
	updateRefs = true
[rerere]
	enabled = true
	autoupdate = true
[core]
	fsmonitor = true

[alias]
    graph = log --graph --branches --oneline --decorate
    ; l = log --graph --pretty=format:'%Cred%h%Creset -%C(auto)%d %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
    l = log --graph --branches --pretty=format:'%C(auto)%h %d %s %Cgreen(%cr) %C(bold blue)<%an>'
